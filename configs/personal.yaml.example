# Personal Assistant Team
# Deploy with: /deploy personal

version: "1"

team: personal

defaults:
  local: true
  runtime: claude-code-cli
  model: claude-opus-4-6
  verbose: "true"
  # Permission bypass for background agents.
  # Default (and recommended) is true: claude-code-cli runs with
  # --dangerously-skip-permissions, codex runs with
  # --dangerously-bypass-approvals-and-sandbox. Background agents have no
  # interactive shell to approve tool-use prompts, so any prompt hangs the
  # process. Set to false only if you understand that your agents will hang
  # the moment a tool-use approval is requested.
  dangerouslySkipPermissions: true

agents:
  - name: x
    description: "Personal X/Twitter — social media monitoring, engagement, content drafting"
    workingDirectory: /Users/nxt3d/projects/id-chain-x

  - name: home
    description: "Personal EA — email triage, calendar, scheduling, personal productivity"
    workingDirectory: /Users/nxt3d/projects/home
