# Personal Assistant Team
# Deploy with: /deploy personal

version: "1"

team: personal

defaults:
  local: true
  runtime: claude-code-cli
  model: claude-opus-4-6
  verbose: "true"
  # Note: --dangerously-skip-permissions is always passed to claude-code-cli
  # subprocesses. There is no YAML knob to disable it (background agents
  # have no shell to approve prompts). See docs/guides/tui.md and QUICKSTART.md.

agents:
  - name: x
    description: "Personal X/Twitter — social media monitoring, engagement, content drafting"
    workingDirectory: /Users/nxt3d/projects/id-chain-x

  - name: home
    description: "Personal EA — email triage, calendar, scheduling, personal productivity"
    workingDirectory: /Users/nxt3d/projects/home
