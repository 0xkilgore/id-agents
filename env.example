# Environment Variables

## Required

# Anthropic API Key (required for Claude agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

## Optional

# Claude Model Selection (default: claude-haiku-4-5-20251001)
# Options:
#   - claude-haiku-4-5-20251001 (fastest, cheapest - 12x cheaper than Sonnet)
#   - claude-sonnet-4-20250514 (balanced, recommended for complex tasks)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Default Plugin Directory (optional)
# Path to a plugin directory that will be loaded for all agents by default
# Can be overridden per-agent using the plugin-path parameter in /spawn
# Example: CLAUDE_DEFAULT_PLUGIN=/workspace/plugins/my-plugin
CLAUDE_DEFAULT_PLUGIN=

# Agent Manager Port (default: 3000)
AGENT_MANAGER_PORT=3000

# Single Agent Server Port (default: 3001)
CLAUDE_AGENT_PORT=3001

# Agent Manager Working Directory (default: /workspace)
AGENT_MANAGER_WORKDIR=/workspace

# ID Agents Manager URL (for SDK/CLI)
ID_MANAGER_URL=http://localhost:3000

# ID Indexer (for /registry pull discovery)
ID_INDEXER_BASE_URL=https://id-indexer.onrender.com
ID_INDEXER_API_KEY=sk-id-YOUR_KEY

# Database Configuration
# For local development:
# DATABASE_URL=postgresql://idagents:idagents@localhost:5433/id_agents
#
# For Hetzner deployment (external database):
# Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:xxxx/railway
# PlanetScale: postgresql://user:password@host:port/database?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://idagents:idagents@localhost:5433/id_agents

# Team namespace (tenant) for the manager + CLI (default: "default")
# This scopes DB rows and the shared folder to `/workspace/teams/<team>/`.
# Preferred:
ID_TEAM=default
# Backwards compatibility (deprecated names):
# ID_PROJECT=default
# ID_CONTAINER=default

# Onchain Registration (for agent registry)
# Sepolia RPC endpoint (required for onchain registration)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-project-id
# AgentRegistrar address on Sepolia (required for onchain registration)
SEPOLIA_REGISTRAR_ADDRESS=0x05f080e221059721116d2761bf4f97327bda7908
# AgentRegistryFactory address on Sepolia (optional; used to deploy a brand-new registry+registrar for a new network)
SEPOLIA_REGISTRY_FACTORY_ADDRESS=0x...
# Private key for registering agents onchain (must have ETH for gas)
ID_REGISTRAR_PRIVATE_KEY=0x...
# Auto-register agents onchain when spawned (default: false)
ID_ONCHAIN_AUTO_REGISTER=false

# Deployment Configuration
# For Hetzner deployment:
DEPLOYMENT_ENV=production  # or 'development'

# Hetzner-specific settings
HETZNER_SSH_KEY=your-ssh-key-name  # SSH key name in Hetzner console

# API Key Authentication
# Admin key for /remote endpoint and /keys/* management
ID_CONTROL_API_KEY=your-admin-api-key
# Inter-agent communication key (used by agents to validate client keys)
ID_AGENT_API_KEY=your-agent-api-key

# Vetra read-side dashboard (Phase 1 of vetra-readside-dashboard plan)
USE_VETRA_DISPATCHES=false
SWITCHBOARD_GRAPHQL_URL=
SWITCHBOARD_ACCESS_TOKEN=
