.env
.env.*
!.env.example
**/agent-wallets.json
**/.env.wallet
*.pem
*.key

# IDE and editor
.idea/
.vscode/
*.swp
*.swo

# Claude Code personal settings (use plugin instead)
.claude/

# Coverage and test artifacts
coverage/
.nyc_output/

# Security files (local only)
SECURITY.md
REVIEW_LOG.md
.xmtp/
