{
  "name": "id-agents",
  "version": "0.1.36-beta",
  "description": "Multi-agent orchestration platform with REST-AP interfaces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "id-agents": "./dist/interactive-agent-cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idchain-world/id-agents.git"
  },
  "homepage": "https://github.com/idchain-world/id-agents#readme",
  "bugs": {
    "url": "https://github.com/idchain-world/id-agents/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "claude": "npm run build && node dist/claude-agent-cli.js",
    "claude:server": "npm run build && node dist/start-claude-server.js",
    "claude:manager": "npm run build && node dist/start-agent-manager.js",
    "claude:talk": "npm run build && node dist/claude-restap-cli.js",
    "id-agents": "tsc 2>/dev/null; node dist/interactive-agent-cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:claude": "npm run build && node dist/test-claude-agent.js",
    "test:claude-client": "npm run build && node dist/examples/test-claude-client.js",
    "demo": "npm run build && node dist/examples/multi-agent-demo.js",
    "demo:inter-agent": "npm run build && node dist/examples/inter-agent-demo.js",
    "local-agent": "npm run build && node dist/local-agent-server.js"
  },
  "files": [
    "dist/**/*",
    "docs/**/*",
    "skills/**/*",
    "plugins/**/*",
    "configs/**/*",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "agents",
    "claude",
    "anthropic",
    "rest-ap",
    "multi-agent"
  ],
  "author": "@nxt3d",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.9",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "viem": "^2.37.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
