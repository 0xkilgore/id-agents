{
  "name": "id-agents",
  "version": "0.1.94-beta",
  "description": "Multi-agent orchestration platform with REST-AP interfaces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "id-agents": "./dist/interactive-agent-cli.js",
    "id-agents-dashboard": "./dist/tui/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idchain-world/id-agents.git"
  },
  "homepage": "https://github.com/idchain-world/id-agents#readme",
  "bugs": {
    "url": "https://github.com/idchain-world/id-agents/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:core": "tsc",
    "build:tui": "tsc -p src/tui/tsconfig.json",
    "build:stamp": "node scripts/write-build-info.mjs",
    "build": "npm run build:core && npm run build:tui && npm run build:stamp",
    "postbuild": "node scripts/ensure-native-abi.mjs && node scripts/link-cli.mjs",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "claude:manager": "npm run build && node dist/start-agent-manager.js",
    "claude:talk": "npm run build && node dist/claude-restap-cli.js",
    "id-agents": "tsc 2>/dev/null; node dist/interactive-agent-cli.js",
    "pretest": "node scripts/ensure-native-abi.mjs",
    "test": "node scripts/run-vitest.mjs",
    "test:watch": "vitest",
    "test:e2e": "ID_CONTROL_API_KEY=${ID_CONTROL_API_KEY:?set ID_CONTROL_API_KEY to run external-manager integration tests} vitest run tests/integration/agent-capabilities.test.ts tests/integration/agent-lifecycle.test.ts tests/integration/agent-relay.test.ts tests/integration/external-client.test.ts tests/integration/remote-commands.test.ts tests/integration/api-key-auth.test.ts tests/integration/require-auth-config.test.ts tests/integration/sync-command.test.ts",
    "test:clean-machine": "vitest run tests/unit/clean-machine-spike.test.ts tests/unit/clean-machine-byo-claude.test.ts && npm run build && node scripts/clean-machine-stranger-smoke.mjs",
    "smoke:orchestration-http": "node scripts/orchestration-http-smoke.mjs",
    "scratch:reap": "npm run build:core && node scripts/scratch-reaper.mjs",
    "local-agent": "npm run build && node dist/local-agent-server.js",
    "tui:dev": "tsx src/tui/index.tsx",
    "tui:build": "npm run build:tui",
    "tui": "npm run tui:build && node dist/tui/index.js"
  },
  "files": [
    "dist/**/*",
    "docs/**/*",
    "skills/**/*",
    "plugins/**/*",
    "configs/**/*",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "agents",
    "claude",
    "anthropic",
    "rest-ap",
    "multi-agent"
  ],
  "author": "@nxt3d",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.9",
    "@xmtp/agent-sdk": "^2.3.0",
    "@xmtp/node-sdk": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "viem": "^2.37.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.28",
    "@types/ws": "^8.18.1",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
