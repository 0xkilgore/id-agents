# ID Agents Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Authentication (choose one approach)
# ===========================================

# Option 1: Anthropic API Key (pay-per-use)
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 2: Claude Max Plan (unlimited usage)
# Run `claude login` first, then agents use your local session

# ===========================================
# Optional: Database
# ===========================================

# PostgreSQL connection (enables persistent news feeds, queries, teams)
# DATABASE_URL=postgresql://user:pass@localhost:5432/id_agents

# ===========================================
# Optional: Security
# ===========================================

# Admin API key for /remote endpoint and /keys management
# ID_CONTROL_API_KEY=your-secure-admin-key

# Inter-agent communication key
# ID_AGENT_API_KEY=your-agent-key

# ===========================================
# Optional: Model Configuration
# ===========================================

# Default Claude model for agents
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ===========================================
# Optional: Public URL
# ===========================================

# Public URL base for agents (when exposing agents externally)
# PUBLIC_BASE_URL=https://idbot.live

# ===========================================
# Optional: Blockchain Integration
# ===========================================

# RPC URL for onchain agent registration
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# Agent registry contract address
# AGENT_REGISTRY_ADDRESS=0x...

# Registrar private key (for minting agent NFTs)
# ID_REGISTRAR_PRIVATE_KEY=0x...
